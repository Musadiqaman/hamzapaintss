<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>View Customer | Hamza Paints</title>
  <link rel="icon" href="/images/weldon-paints-logo.png" type="image/png">
  <link rel="stylesheet" href="/stylesheets/viewCustomer.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <a href="/customers/all" id="BackBtn"><span class="backbtn">←</span> All Customers</a>

    <h1>View Customer - <span style="color: #2196F3;"><%= customer.name %></span></h1>

    <div class="top-actions">
      <button id="editAgentBtn">✏️ Edit Profile</button>
      <button id="viewHistoryBtn">📜 Payment History</button>
      <button id="collectivePayBtn" style="background:#1565c0; color:white; border:none;
        padding:8px 16px; border-radius:6px; cursor:pointer; font-weight:bold; font-size:14px;">
        💰 Collective Payment
      </button>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="custom-modal">
      <div class="modal-content">
        <div class="modal-header blue-header">Edit Customer Profile</div>
        <div class="modal-body">
          <div class="form-group">
            <label>Customer Name</label>
            <input type="text" id="editName" value="<%= customer.name %>">
          </div>
          <div class="form-group">
            <label>Phone Number</label>
            <input type="text" id="editPhone" value="<%= customer.phone || '' %>">
          </div>
        </div>
        <div class="modal-footer">
          <button id="saveAgentBtn" class="btn-m btn-save"
            style="background:#06a56c; color:white; border:none; padding:8px 15px; border-radius:5px;">
            Save Changes
          </button>
          <button id="closeEditModal" class="btn-m btn-cancel"
            style="background:#ccc; border:none; padding:8px 15px; border-radius:5px;">
            Cancel
          </button>
        </div>
      </div>
    </div>

    <!-- Payment History Modal -->
    <div id="historyModal" class="custom-modal">
      <div class="modal-content">
        <div class="modal-header orange-header">Payment History 📜</div>
        <div class="modal-body scroll-body">
          <table class="history-table">
            <thead>
              <tr style="background:#f4f4f4; color:#333;">
                <th>Date</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody id="historyTableBody"></tbody>
          </table>
        </div>
        <div class="modal-footer">
          <button id="closeHistoryModal" class="btn-m btn-cancel"
            style="margin-top:15px; background:#666; color:white; border:none; padding:8px 20px; border-radius:5px;">
            Close
          </button>
        </div>
      </div>
    </div>

    <!-- ✅ Collective Payment Modal -->
    <div id="collectiveModal" class="custom-modal">
      <div class="modal-content">
        <div class="modal-header" style="background:#1565c0; color:white; padding:16px 20px; font-size:16px; font-weight:bold; border-radius:8px 8px 0 0;">
          💰 Collective Payment
        </div>
        <div class="modal-body">
          <p style="color:#555; font-size:14px; margin-bottom:16px;">
            Ek amount daalo — system automatically purane bill se shuru karke saare outstanding bills mein distribute karega.
          </p>
          <div class="form-group">
            <label style="font-weight:bold; color:#333; display:block; margin-bottom:6px;">Total Amount (Rs.)</label>
            <input type="number" id="collectiveAmount" min="1" placeholder="e.g. 5000"
              style="width:100%; padding:10px; border:1px solid #ccc; border-radius:6px; font-size:15px; box-sizing:border-box;">
          </div>
          <div id="collectiveResult" style="margin-top:12px; font-size:14px;"></div>
        </div>
        <div class="modal-footer">
          <button id="submitCollectivePay"
            style="background:#1565c0; color:white; border:none; padding:9px 20px;
                   border-radius:5px; font-weight:bold; cursor:pointer; font-size:14px;">
            ✅ Submit Payment
          </button>
          <button id="closeCollectiveModal"
            style="background:#ccc; border:none; padding:9px 16px; border-radius:5px;
                   cursor:pointer; margin-left:8px; font-size:14px;">
            Cancel
          </button>
        </div>
      </div>
    </div>

    <div class="filter-container">
      <select id="filter">
        <option value="all"       <%= filter === 'all'       ? 'selected' : '' %>>All Times</option>
        <option value="today"     <%= filter === 'today'     ? 'selected' : '' %>>Today</option>
        <option value="yesterday" <%= filter === 'yesterday' ? 'selected' : '' %>>Yesterday</option>
        <option value="month"     <%= filter === 'month'     ? 'selected' : '' %>>This Month</option>
        <option value="lastMonth" <%= filter === 'lastMonth' ? 'selected' : '' %>>Last Month</option>
        <option value="custom"    <%= filter === 'custom'    ? 'selected' : '' %>>Custom Range</option>
      </select>
      <input type="date" id="from" value="<%= from || '' %>" style="display:none;">
      <input type="date" id="to"   value="<%= to   || '' %>" style="display:none;">
      <button type="button" id="apply">Apply Filter</button>
    </div>

    <div class="stats">
      <div class="stat-box">
        <h3>Total Outstanding 💵</h3>
        <p id="stat-total">Rs <%= Number(stats.totalOutstandingAmount).toFixed(2) %></p>
      </div>
      <div class="stat-box">
        <h3>Paid Outstanding ✅</h3>
        <p id="stat-paid" style="color:#8B5CF6; font-weight:bold;">
          Rs <%= Number(stats.totalOutstandingAmountGiven).toFixed(2) %>
        </p>
      </div>
      <div class="stat-box">
        <h3>Left Outstanding ⏳</h3>
        <p id="stat-left" style="color:#f44336;">
          Rs <%= Number(stats.totalOutstandingAmountLeft).toFixed(2) %>
        </p>
      </div>
    </div>

    <div class="table-container">
      <div id="tableLoader">
        <div class="spinner"></div>
        <p style="margin-top:10px; color:#06A56C; font-weight:bold;">Updating...</p>
      </div>

      <table>
        <thead>
          <tr>
            <th>Quantity Sold</th>
            <th>Total Amount</th>
            <th>Status</th>
            <th>Paid</th>
            <th>Left</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="agentTableBody">
          <% if (!customer.items || customer.items.length === 0) { %>
            <tr><td colspan="9" class="no-data">No records found.</td></tr>
          <% } else { %>
            <% customer.items.forEach(i => { %>
              <tr id="row-<%= i._id %>">
                <td><%= i.totalProductSold %></td>
                <td>Rs <%= Number(i.totalProductAmount || 0).toFixed(2) %></td>
                <td class="paid-status">
                  <span class="status-tag">
                    <%= i.paidAmount >= i.totalProductAmount ? 'Paid' : (i.paidAmount > 0 ? 'Partially' : 'Unpaid') %>
                  </span>
                </td>
                <td style="color:#8B5CF6; font-weight:bold;">Rs <%= Number(i.paidAmount || 0).toFixed(2) %></td>
                <td style="color:red; font-weight:bold;">Rs <%= (Number(i.totalProductAmount) - Number(i.paidAmount)).toFixed(2) %></td>
                <td>
                  <%
                    let dateObj = new Date(i.createdAt);
                    let pkrDate = dateObj.toLocaleDateString('en-GB', {
                      day: '2-digit', month: '2-digit', year: 'numeric',
                      timeZone: 'Asia/Karachi'
                    });
                    let pkrTime = dateObj.toLocaleTimeString('en-US', {
                      hour: '2-digit', minute: '2-digit', hour12: true,
                      timeZone: 'Asia/Karachi'
                    });
                  %>
                  <div><%= pkrDate %></div>
                  <small style="color:#2196F3; font-weight:bold;"><%= pkrTime %></small>
                  <% if (i.billId) { %>
                    <div style="margin-top:5px;">
                      <a href="/sales/bill/<%= i.billId._id %>"
                         style="color:#2196F3; text-decoration:none; font-size:11px; font-weight:bold;">
                         📄 View Bill
                      </a>
                    </div>
                  <% } else { %>
                    <div style="margin-top:5px;">
                      <small style="color:#999; font-size:11px; font-weight:bold;">No Bill</small>
                    </div>
                  <% } %>
                </td>
                <td class="actions">
                  <button class="pay-btn" data-id="<%= i._id %>">Pay</button>
                  <% if(role == "admin") { %>
                    <button class="delete-btn" data-id="<%= i._id %>">Delete</button>
                  <% } %>
                  <div class="pay-box" id="paybox-<%= i._id %>" style="display:none; margin-top:5px;">
                    <input class="payinput" type="number" id="payInput-<%= i._id %>"
                           style="width:70px" min="1" placeholder="Pay">
                    <button class="submit-pay-btn" data-id="<%= i._id %>">Submit</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <script src="/javascripts/viewCustomer.js"></script>
</body>
</html>
