<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>All Companies | Hamza Paints</title>
  <link rel="icon" href="/images/weldon-paints-logo.png" type="image/png">
  <link rel="stylesheet" href="/stylesheets/allCompanys.css">
</head>

<body>
  <%- include('partials/navbar') %>

  <main>
    <h1>All Companies</h1>

    <form class="filter-container" id="filterForm" style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
      <select name="filter" id="filter">
        <option value="all"       <%= filter === 'all' || !filter ? 'selected' : '' %>>All Times</option>
        <option value="today"     <%= filter === 'today'     ? 'selected' : '' %>>Today</option>
        <option value="yesterday" <%= filter === 'yesterday' ? 'selected' : '' %>>Yesterday</option>
        <option value="month"     <%= filter === 'month'     ? 'selected' : '' %>>This Month</option>
        <option value="lastMonth" <%= filter === 'lastMonth' ? 'selected' : '' %>>Last Month</option>
        <option value="custom"    <%= filter === 'custom'    ? 'selected' : '' %>>Custom Range</option>
      </select>

      <input type="date" name="from" id="from" value="<%= from || '' %>" style="display:none;">
      <input type="date" name="to"   id="to"   value="<%= to   || '' %>" style="display:none;">

      <button type="button" id="apply">Apply Filter</button>

      <span style="color:#ccc; margin:0 10px;">|</span>

      <input type="text" id="billSearchInput" placeholder="Enter Phone Or Name"
        style="padding:8px; border:1px solid #ccc; border-radius:4px; width:200px;">
      <button type="button" id="searchBillBtn">Search</button>
    </form>

    <!-- Stats -->
    <div class="stats">
      <div class="stat-box">
        <h3>🏢 Total Companies</h3>
        <p><%= stats.totalCompanies %></p>
      </div>
      <div class="stat-box">
        <h3>Total Obrai 💵</h3>
        <p>Rs <%= Number(stats.totalOutstandingAmount || 0).toFixed(2) %></p>
      </div>
      <div class="stat-box">
        <h3>Paid Obrai ✅</h3>
        <p style="color: #8B5CF6 ; font-weight:bold;" >Rs <%= Number(stats.totalOutstandingAmountGiven || 0).toFixed(2) %></p>
      </div>
      <div class="stat-box" id="negative">
        <h3>Left Obrai ⏳</h3>
        <p>Rs <%= Number(stats.totalOutstandingAmountLeft || 0).toFixed(2) %></p>
      </div>
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-container">
      <div class="pagination-info">
        Showing <strong id="showingFrom">0</strong> –
        <strong id="showingTo">0</strong>
        of <strong id="totalCount">0</strong> Companies
      </div>
      <div class="pagination-controls">
        <select id="limitSelect">
          <option value="25"  <%= pagination.limit == 25  ? 'selected' : '' %>>25 / page</option>
          <option value="50"  <%= pagination.limit == 50  ? 'selected' : '' %>>50 / page</option>
          <option value="100" <%= pagination.limit == 100 ? 'selected' : '' %>>100 / page</option>
          <option value="200" <%= pagination.limit == 200 ? 'selected' : '' %>>200 / page</option>
        </select>
        <button id="prevPage" <%= !pagination.hasPrev ? 'disabled' : '' %>>← Prev</button>
        <span id="pageInfo">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
        <button id="nextPage" <%= !pagination.hasNext ? 'disabled' : '' %>>Next →</button>
      </div>
    </div>

    <!-- Table -->
    <div class="table-container" id="tableContainer">
      <div id="table-loader" style="display:none;">
        <div class="spinner"></div>
        <p style="margin-top:10px; color:#06A56C; font-weight:bold;">Updating...</p>
      </div>

      <table>
        <thead>
          <tr>
            <th>Company Name</th>
            <th>Company Phone</th>
            <th>Obrai Amount Left</th>
            <th>Register Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="companyTableBody">
          <% if (companies.length === 0) { %>
            <tr><td colspan="5" class="no-data">No Companies found.</td></tr>
          <% } else { %>
            <% companies.forEach(c => { %>
              <tr>
                <td><%= c.name %></td>
                <td><%= c.phone %></td>
                <td style="color:red; font-weight:bold;">
                  <%= (c.calculatedLeft || 0).toLocaleString() %>
                </td>
                <td>
                  <%= new Date(c.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric', timeZone:'Asia/Karachi' }) %>
                  <br>
                  <small style="color:#007bff; font-weight:bold;">
                    <%= new Date(c.createdAt).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit', hour12:true, timeZone:'Asia/Karachi' }) %>
                  </small>
                </td>
                <td class="action-buttons">
                  <button id="view">
                    <a href="/company/view/<%= c._id %>" style="text-decoration:none; color:inherit;"  >View</a>
                  </button>
                  <% if (role == "admin") { %>
                    <button class="delete-btn" data-id="<%= c._id %>" id="delete" >Delete</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Hidden data provider for JS -->
    <div id="db-data-provider"
      data-page="<%= pagination.page %>"
      data-limit="<%= pagination.limit %>"
      data-total-pages="<%= pagination.totalPages %>"
      data-total-count="<%= pagination.totalCount %>"
      style="display:none;">
    </div>

  </main>

  <script src="/javascripts/allCompanys.js"></script>
</body>
</html>


