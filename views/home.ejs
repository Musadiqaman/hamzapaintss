<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Home | Hamza Paints</title>
  <link rel="icon" href="/images/weldon-paints-logo.png" type="image/png">
  <link rel="stylesheet" href="/stylesheets/home.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main class="dashboard">

    <section class="welcome glass-panel">
      <div class="welcome-text">
        <h1>Welcome to Dashboard</h1>
        <p>Complete overview of your paint store management system</p>
      </div>
    </section>



  


    <div class="calculator-container">

      <!-- FILTER -->
     <form id="filterForm">
     <select name="filter" id="filterSelect">
    <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All Times</option>
    <option value="today" <%= filter === 'today' ? 'selected' : '' %>>Today</option>
    <option value="yesterday" <%= filter === 'yesterday' ? 'selected' : '' %>>Yesterday</option>
    <option value="month" <%= (filter === 'month' || !filter) ? 'selected' : '' %>>This Month</option>
    <option value="lastMonth" <%= filter === 'lastMonth' ? 'selected' : '' %>>Last Month</option>
    <option value="custom" <%= filter === 'custom' ? 'selected' : '' %>>Custom Range</option>
  </select>

  <input type="date" name="from" id="fromDate" value="<%= from || '' %>">
  <input type="date" name="to" id="toDate" value="<%= to || '' %>">
  
  <button type="submit" id="apply">Apply Filter</button>
</form>
     <br>
      <!-- Loader -->
      <div class="spinner" id="loader" style="display:none;"></div>

      <!-- Calculator Grid -->
      <div class="calculator-grid" id="calculatorGrid">
        <%- include('partials/calculator-grid', { stats }) %>
      </div>
    </div>

    <!-- 🚗 Car Game Floating Button -->
<button id="carOpenBtn" title="Car Dodge 🚗">🚗</button>

<!-- 🚗 Car Game Modal -->
<div id="carModal">
  <div class="car-modal-content">
    <div class="car-header">
      <h2>🚗 Car Dodge</h2>
      <div class="car-header-actions">
        <button id="carSoundBtn">🔊</button>
        <button id="closeCarModal">✕</button>
      </div>
    </div>

    <div class="car-scorebar">
      <div><span class="car-label">Score</span><span id="carScore">0</span></div>
      <div><span class="car-label">Best</span><span id="carBest">0</span></div>
    </div>

    <div class="car-canvas-wrap">
      <canvas id="carCanvas" width="240" height="360"></canvas>
      <div id="carGameOverOverlay">
        <h3>Crashed 💥</h3>
        <p>Score: <span id="carFinalScore"></span></p>
        <button id="carRestartBtn">Play Again</button>
      </div>
    </div>

    <div class="car-dpad">
      <button class="car-dpad-btn" data-dir="left">⬅️</button>
      <button class="car-dpad-btn" data-dir="right">➡️</button>
    </div>

    <p class="car-hint">Use arrow keys or swipe to switch lanes 🎮</p>
  </div>
</div>

  </main>

  <script src="/javascripts/home.js"></script>
  <script src="/javascripts/snake.js"></script>
</body>
</html>

