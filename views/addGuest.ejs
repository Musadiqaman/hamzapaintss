<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Guest | Hamza Paints</title>
    <link rel="icon" href="/images/weldon-paints-logo.png" type="image/png">
   <link rel="stylesheet" href="/stylesheets/addGuest.css">
</head>
<body>

    <%- include('partials/navbar') %>
<main>
<div class="container">

    <div class="content-section">
        <h4>➕ Add Guest Expense (Chai / Cold Drink)</h4>
        <br>
        <form id="guestExpenseForm">
            
            <div class="form-group">
                <label>Guest Name / Mehman Ka Naam</label>
                <input type="text" name="guestName" id="guestName" class="form-control" placeholder="e.g., Bilal Khan" required>
            </div>

            <div class="form-group">
                <label>Description / Detail</label>
                <input type="text" name="title" id="title" class="form-control" placeholder="e.g., Chai aur Biscuit" required >
            </div>

            <div class="form-group">
                <label>Amount (Rs.)</label>
                <input type="number" name="amount" id="amount" class="form-control" placeholder="e.g., 250" required>
            </div>

            <div class="form-group">
                <label>Remarks / Notes (Optional)</label>
                <input type="text" name="remarks" id="remarks" class="form-control" placeholder="e.g., Malik Sahab k Mehman">
            </div>

            <button type="submit" id="add">
                Save Entry & Deduct from Profit
            </button>

        </form>
    </div>

</div>
</main>

<script src="/javascripts/addGuest.js"></script>
</body>
</html>