<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>View Agent | Hamza Paints</title>
  <link rel="icon" href="/images/weldon-paints-logo.png" type="image/png">
  <link rel="stylesheet" href="/stylesheets/viewAgent.css">


</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <a href="/agents/all" id="BackBtn"><span class="backbtn">←</span> All Agents</a>

    <h1>View Agent - <span style="color: #2196F3;"><%= agent.name %></span></h1>

    <div class="top-actions" >
    <button id="editAgentBtn" >✏️ Edit Profile</button>
    <button id="viewHistoryBtn">📜 Payment History</button>
</div>

<div id="editModal" class="custom-modal">
    <div class="modal-content">
        <div class="modal-header blue-header">Edit Agent Profile</div>
        <div class="modal-body">
            <div class="form-group">
                <label>Agent Name</label>
                <input type="text" id="editName" value="<%= agent.name %>">
            </div>
            <div class="form-group">
                <label>Phone Number</label>
                <input type="text" id="editPhone" value="<%= agent.phone || '' %>">
            </div>
        </div>
        <div class="modal-footer">
            <button id="saveAgentBtn" class="btn-m btn-save" style="background: #06a56c; color: white; border: none; padding: 8px 15px; border-radius: 5px;" >Save Changes</button>
            <button id="closeEditModal" class="btn-m btn-cancel" style="background: #ccc; border: none; padding: 8px 15px; border-radius: 5px;">Cancel</button>
        </div>
    </div>
</div>

<div id="historyModal" class="custom-modal">
    <div class="modal-content">
        <div class="modal-header orange-header">Payment History 📜</div>
        <div class="modal-body scroll-body">
            <table class="history-table">
                <thead>
                    <tr style="background:#f4f4f4; color:#333;">
                        <th>Date</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody id="historyTableBody">
                    </tbody>
            </table>
        </div>
        <div class="modal-footer">
            <button id="closeHistoryModal" class="btn-m btn-cancel" class="close-modal" style="margin-top: 15px; background: #666; color: white; border: none; padding: 8px 20px; border-radius: 5px;">Close</button>
        </div>
    </div>
</div>
    <div class="filter-container">
      <select id="filter">
        <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All Times</option>
        <option value="today" <%= filter === 'today' ? 'selected' : '' %>>Today</option>
        <option value="yesterday" <%= filter === 'yesterday' ? 'selected' : '' %>>Yesterday</option>
        <option value="month" <%= filter === 'month' ? 'selected' : '' %>>This Month</option>
        <option value="lastMonth" <%= filter === 'lastMonth' ? 'selected' : '' %>>Last Month</option>
        <option value="custom" <%= filter === 'custom' ? 'selected' : '' %>>Custom Range</option>
      </select>

      <input type="date" id="from" value="<%= from || '' %>" style="display:none;">
      <input type="date" id="to" value="<%= to || '' %>" style="display:none;">
      <button type="button" id="apply">Apply Filter</button>
    </div>

    <div class="stats">
      <div class="stat-box">
        <h3>Total Commission 💵</h3>
        <p id="stat-total">Rs <%= Number(stats.totalPercentageAmount).toFixed(2) %></p>
      </div>
      <div class="stat-box">
        <h3>Paid Commission ✅</h3>
        <p id="stat-paid" style="color: #8B5CF6 ; font-weight:bold;" >Rs <%= Number(stats.totalPercentageAmountGiven).toFixed(2) %></p>
      </div>
      <div class="stat-box">
        <h3>Left Commission ⏳</h3>
        <p id="stat-left" style="color: #f44336;">Rs <%= Number(stats.totalPercentageAmountLeft).toFixed(2) %></p>
      </div>
    </div>

    <div class="table-container">
      <div id="tableLoader">
        <div class="spinner"></div>
        <p style="margin-top:10px; color:#06A56C; font-weight: bold;">Updating...</p>
      </div>

      <table>
        <thead>
          <tr>
            <th>Quantity Sold</th>
            <th>Total Amount</th>
            <th>%</th>
            <th>% Amount</th>
            <th>Status</th>
            <th>Paid</th>
            <th>Left</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
       <tbody id="agentTableBody">
  <% if (!agent.items || agent.items.length === 0) { %>
    <tr>
      <td colspan="9" class="no-data">No records found.</td>
    </tr>
  <% } else { %>
    <% agent.items.forEach(i => { %>
      <tr id="row-<%= i._id %>">
        <td><%= i.totalProductSold %></td>
        <td>Rs <%= Number(i.totalProductAmount || 0).toFixed(2) %></td>
        <td><%= i.percentage %>%</td>
        <td>Rs <%= Number(i.percentageAmount || 0).toFixed(2) %></td>
        <td class="paid-status">
          <span class="status-tag">
            <%= i.paidAmount >= i.percentageAmount ? 'Paid' : (i.paidAmount > 0 ? 'Partially' : 'Unpaid') %>
          </span>
        </td>
        <td style="color: #8B5CF6 ; font-weight:bold;" >Rs <%= Number(i.paidAmount || 0).toFixed(2) %></td>
        <td style="color:red; font-weight:bold;" >Rs <%= (Number(i.percentageAmount) - Number(i.paidAmount)).toFixed(2) %></td>
        <td>
          <div>
            <% 
              let dateObj = new Date(i.createdAt);
              let pkrDate = dateObj.toLocaleDateString('en-GB', { 
                  day: '2-digit', month: '2-digit', year: 'numeric', 
                  timeZone: 'Asia/Karachi' 
              });
              let pkrTime = dateObj.toLocaleTimeString('en-US', { 
                  hour: '2-digit', minute: '2-digit', hour12: true, 
                  timeZone: 'Asia/Karachi' 
              });
            %>
            <%= pkrDate %>
          </div>
          <small style="color: #2196F3; font-weight: bold;">
            <%= pkrTime %>
          </small>

          <% if (i.billId) { %>
    <div style="margin-top: 5px;">
      <a href="/sales/bill/<%= i.billId._id %>"  
         style="color: #2196F3; text-decoration: none; font-size: 11px; font-weight: bold;">
         📄 View Bill
      </a>
    </div>
  <% } else { %>
    <div style="margin-top: 5px;">
      <small style="color: #999; font-size: 11px; font-weight: bold;">No Bill</small>
    </div>
  <% } %>
        </td>
        <td class="actions">
          <button class="pay-btn" data-id="<%= i._id %>"  >Pay %</button>
          
          <% if(role == "admin") { %>
            <button class="delete-btn" data-id="<%= i._id %>">Delete</button>
          <% } %>
          
          <div class="pay-box" id="paybox-<%= i._id %>" style="display:none; margin-top:5px;">
            <input class="payinput" type="number" id="payInput-<%= i._id %>" 
                   style="width:70px" min="1" placeholder="Pay">
            <button class="submit-pay-btn" data-id="<%= i._id %>" id="submit" >Submit</button>
          </div>
        </td>
      </tr>
    <% }) %>
  <% } %>
</tbody>
      </table>
    </div>
  </main>



  

  <script src="/javascripts/viewAgent.js"></script>
</body>
</html>


